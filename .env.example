# Copy this file to .env and fill in your values
# cp .env.example .env

# Required
OPENAI_API_KEY=sk-...
SECRET_KEY=change-me-to-a-random-secret

# Database — point at an existing MySQL instance (Docker Compose does not spin one up)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=food_recognition

# Optional
DEFAULT_DAYS=30
DB_TZ_DATES=UTC
WAIT_TIME_OPEANAI_API=5
